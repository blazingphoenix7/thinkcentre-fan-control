                {
                    ADBG ("Win Sata DSM UUID : E4DB149B-FCFE-425b-A6D8-92357D78FC7F")
                    Return (One)
                }
                Else
                {
                    Return (Zero)
                }
            }

            Method (SATD, 4, Serialized)
            {
                If (CondRefOf (ZPOV))
                {
                    Return (ZPOV (Arg1, Arg2, Arg3))
                }
                Else
                {
                    Switch (ToInteger (Arg2))
                    {
                        Case (Zero)
                        {
                            ADBG ("Win Sata DSM fun 0")
                            Return (Buffer (One)
                            {
                                 0x03                                             // .
                            })
                        }
                        Default
                        {
