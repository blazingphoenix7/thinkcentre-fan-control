        Method (_WED, 1, NotSerialized)  // _Wxx: Wake Event, xx=0x00-0xFF
        {
            Acquire (GWMI, 0xFFFF)
            If ((Arg0 == 0xA0))
            {
                DBGP = 0xE1
                Local0 = ICEM /* \WMI2.ICEM */
                If ((Local0 == 0x02))
                {
                    DBGP = 0xBE
                    Release (GWMI)
                    Return (0x02)
                }

                If ((Local0 == One))
                {
                    DBGP = 0xB8
                    Release (GWMI)
                    Return (0x03)
                }

                Release (GWMI)
                Return (Zero)
            }

            If ((Arg0 == 0xA1))
            {
                Release (GWMI)
                Return (Zero)
            }

            Release (GWMI)
            Return (Zero)
        }

