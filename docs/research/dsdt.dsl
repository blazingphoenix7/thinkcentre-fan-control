                                    })
                                }
                                Case (One)
                                {
                                    If ((CondRefOf (\DLRM) && (DLRM != Zero)))
                                    {
                                        ADBG ("Enable DLRM for Storage")
                                        Return (One)
                                    }
                                    Else
                                    {
                                        ADBG ("Disable DLRM for Storage")
                                        Return (Zero)
                                    }
                                }

                            }
                        }
                    }

                    If ((Arg0 == ToUUID ("9cd9cddd-8845-4afd-8392-31c4eb87cabd") /* Unknown UUID */))
                    {
                        Switch (ToInteger (Arg2))
                        {
