                /* 0028 */  0x00, 0x00, 0x87, 0x17, 0x00, 0x00, 0x0C, 0x01,  // ........
                /* 0030 */  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xB0,  // ........
                /* 0038 */  0xFF, 0xFF, 0xFF, 0xBF, 0x00, 0x00, 0x00, 0x00,  // ........
