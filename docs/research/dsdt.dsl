                        Debug = "SIOW"
                        ENFG (0x04)
                        PMFG = OPT1 /* \_SB_.PC00.LPCB.SIO1.OPT1 */
                        OPT1 = 0xFF
                        OPT0 &= 0xE7
                        OPT0 &= 0xBF /* \_SB_.PC00.LPCB.SIO1.OPT0 */
                        LDN = 0x06
                        ACTR = One
                        LDN = 0x05
                        ACTR = One
                        EXFG ()
                    }

