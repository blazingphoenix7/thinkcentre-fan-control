                }
            }

            Name (LINK, "\\_SB.GPI0")
            Method (_CRS, 0, NotSerialized)  // _CRS: Current Resource Settings
            {
                Name (RBPS, Buffer (0x2F)
                {
                    /* 0000 */  0x89, 0x06, 0x00, 0x0D, 0x01, 0x0E, 0x00, 0x00,  // ........
                    /* 0008 */  0x00, 0x86, 0x09, 0x00, 0x01, 0x00, 0x00, 0x00,  // ........
                    /* 0010 */  0x00, 0x00, 0x00, 0x01, 0x00, 0x86, 0x09, 0x00,  // ........
                    /* 0018 */  0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x01,  // ........
                    /* 0020 */  0x00, 0x86, 0x09, 0x00, 0x01, 0x00, 0x00, 0x00,  // ........
                    /* 0028 */  0x00, 0x00, 0x00, 0x01, 0x00, 0x79, 0x00         // .....y.
                })
                CreateDWordField (RBPS, 0x05, INTH)
                INTH = SGIR /* \SGIR */
                CreateDWordField (RBPS, 0x0D, CMH0)
                CMH0 = (SBRG + 0x00D10000)
                CreateDWordField (RBPS, 0x19, CMH1)
                CMH1 = (SBRG + 0x00D20000)
                CreateDWordField (RBPS, 0x25, CMH3)
                CMH3 = (SBRG + 0x00D30000)
                If ((PCHS != 0x04))
                {
                    Name (RBFS, Buffer (0x1A)
                    {
                        /* 0000 */  0x86, 0x09, 0x00, 0x01, 0x00, 0x00, 0x00, 0x00,  // ........
                        /* 0008 */  0x00, 0x00, 0x01, 0x00, 0x86, 0x09, 0x00, 0x01,  // ........
                        /* 0010 */  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x01, 0x00,  // ........
                        /* 0018 */  0x79, 0x00                                       // y.
                    })
                    CreateDWordField (RBFS, 0x04, CMH4)
                    CMH4 = (SBRG + 0x00D40000)
                    CreateDWordField (RBFS, 0x10, CMH5)
                    CMH5 = (SBRG + 0x00D50000)
                    ConcatenateResTemplate (RBPS, RBFS, Local0)
                    Return (Local0)
                }

                Return (RBPS) /* \_SB_.GPI0._CRS.RBPS */
            }

            Method (_STA, 0, NotSerialized)  // _STA: Status
            {
                If ((GPHD == One))
                {
                    Return (0x08)
                }

                Return (0x0F)
            }
        }
