        TXBF,   8, 
        DLM,    8, 
        FCR,    8, 
        LCR,    8
    }

    Method (SDBG, 1, Serialized)
    {
        Name (TXBU, Zero)
        Name (DLBU, Zero)
        Name (FCBU, Zero)
        Name (LCBU, Zero)
        TXBU = TXBF /* \TXBF */
        DLBU = DLM /* \DLM_ */
        FCBU = FCR /* \FCR_ */
        LCBU = LCR /* \LCR_ */
        LCR = 0x83
        TXBF = One
        DLM = Zero
        FCR = 0xE1
        LCR = 0x03
        DLM = Zero
        ToHexString (Arg0, Local3)
        Local4 = SizeOf (Local3)
        Local5 = Zero
        While ((Local5 < Local4))
        {
            Mid (Local3, Local5, One, TXBF) /* \TXBF */
            Stall (0x64)
            Local5++
        }

        Stall (0x64)
        TXBF = 0x0D
        Stall (0x64)
        TXBF = 0x0A
        TXBF = TXBU /* \SDBG.TXBU */
        DLM = DLBU /* \SDBG.DLBU */
        FCR = FCBU /* \SDBG.FCBU */
        LCR = LCBU /* \SDBG.LCBU */
    }

    OperationRegion (SPRT, SystemIO, 0xB2, 0x02)
    Field (SPRT, ByteAcc, Lock, Preserve)
