                            Offset (0x52), 
                                ,   13, 
                            LASX,   1, 
                            Offset (0xE0), 
                            SCB0,   1, 
                            Offset (0xE2), 
                                ,   3, 
                            L23R,   1, 
                            Offset (0x328), 
                            Offset (0x32B), 
                            LTSM,   8, 
                            Offset (0x420), 
                                ,   30, 
