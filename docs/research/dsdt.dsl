                        DL23 ()
                        ADBG ("WWAN DL23() Done")
                        ^^^^PGPI.SGOV (PRST, WPRP)
                        ADBG ("WWAN PERST:0 Done")
                    }
                    Else
                    {
                        ADBG ("Assume WWAN DL23() is already done")
                    }

                    Sleep (TR2B)
                    ^^^^PGPI.SGOV (WBRS, PBRS)
