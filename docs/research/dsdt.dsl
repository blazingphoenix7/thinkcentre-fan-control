                /* 0048 */  0x0C, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // ........
                /* 0050 */  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x40, 0x00,  // ......@.
                /* 0058 */  0x00, 0x00, 0xFF, 0xFF, 0xFF, 0xFF, 0x5F, 0x00,  // ......_.
                /* 0060 */  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  // ........
                /* 0068 */  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x20, 0x00,  // ...... .
                /* 0070 */  0x00, 0x00, 0x79, 0x00                           // ..y.
            })
            Method (_CRS, 0, Serialized)  // _CRS: Current Resource Settings
            {
                CreateWordField (BUF0, 0x0A, PBMX)
                CreateWordField (BUF0, 0x08, PBMN)
                CreateWordField (BUF0, 0x0E, PBLN)
                PBMN = PBSB /* External reference */
                PBMX = PBSL /* \PBSL */
                PBLN = (PBMX - PBMN) /* \_SB_.PC02._CRS.PBMN */
                PBLN += One
                CreateDWordField (BUF0, 0x1A, I1MN)
                CreateDWordField (BUF0, 0x1E, I1MX)
                CreateDWordField (BUF0, 0x26, I1LN)
