                            {
                                WRST, 
                            })
                        }
                    }

                    If (((WWEN != Zero) && (WWRP == SLOT)))
                    {
                        If (CondRefOf (MRST))
                        {
                            Return (Package (0x01)
                            {
                                MRST, 
                            })
