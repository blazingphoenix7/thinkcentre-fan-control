        Method (WMG0, 3, NotSerialized)
        {
            Acquire (GWMI, 0xFFFF)
            If ((Arg1 == One))
            {
                DBGP = One
                Release (GWMI)
                Return (Buffer (0x04)
                {
                     0x0A, 0x00, 0x00, 0x00                           // ....
                })
            }

            If ((Arg1 == 0x02))
            {
                DBGP = 0x02
                Release (GWMI)
                Return (Buffer (0x04)
                {
                     0x00, 0x00, 0x00, 0x00                           // ....
                })
            }

            If ((Arg1 == 0x03))
            {
                DBGP = 0x03
                Release (GWMI)
                Return (Buffer (0x04)
                {
                     0x04, 0x00, 0x00, 0x00                           // ....
                })
            }

            If ((Arg1 == 0x04))
            {
                DBGP = 0x04
                Release (GWMI)
                Return (Buffer (0x04)
                {
                     0x0E, 0x00, 0x00, 0x00                           // ....
                })
            }

            If ((Arg1 == 0x05))
            {
                DBGP = 0x05
                SFAN = Arg2
                CMIN = 0xC9
                Local0 = CMDA /* \WMI2.CMDA */
                If ((Local0 == 0x02))
                {
                    ICEM = 0x02
                    \_SB.ODV0 = 0x02
                    Notify (WMI2, 0xA0) // Device-Specific
                }

                If ((Local0 == 0x03))
                {
                    ICEM = One
                    \_SB.ODV0 = One
                    Notify (WMI2, 0xA0) // Device-Specific
                }

                If ((Local0 == 0x04))
                {
                    ICEM = 0x05
                    \_SB.ODV0 = 0x05
                    Notify (WMI2, 0xA0) // Device-Specific
                }

                If (CondRefOf (\_SB.IETM))
                {
                    Notify (\_SB.IETM, 0x88) // Device-Specific
                }

                Release (GWMI)
                GSMI = 0x78
                Return (Zero)
            }

