                            Offset (0x32B), 
                            LTSM,   8, 
                            Offset (0x404), 
                            LSOE,   1, 
                            LNSE,   1
                        }

                        ADBG (Concatenate ("VMD PCIe RP LTSSM at RL23 Start -", ToHexString (LTSM)))
                        If (((LASX == One) && (LNRE == Zero)))
                        {
                            If (((LSOE == One) || (LNSE == One)))
                            {
                                LNRE = One
                                Sleep (One)
                                LNRE = Zero
                                ADBG ("Toggle LNRE")
                            }
