                /* 0008 */  0x81, 0x00, 0xFF, 0x00, 0x00, 0x00, 0x7F, 0x00,  // ........
                /* 0010 */  0x87, 0x17, 0x00, 0x01, 0x0C, 0x03, 0x00, 0x00,  // ........
